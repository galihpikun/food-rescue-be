generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  role       Role        @default(CUSTOMER)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  fullname   String
  orders     Order[]
  restaurant Restaurant?
  reviews    Review[]    // <-- Relasi ke tabel Review
}

model Restaurant {
  id           String    @id @default(uuid())
  name         String
  address      String
  description  String?
  totalRevenue Int       @default(0)
  userId       String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
  user         User      @relation(fields: [userId], references: [id])
}

model Category {
  id           Int       @id @default(autoincrement())
  categoryName String?
  products     Product[]
}

model Product {
  id                 String      @id @default(uuid())
  name               String
  description        String
  type               ProductType @default(REGULAR)
  originalPrice      Int
  sellingPrice       Int
  stock              Int         @default(1)
  imageUrl           String?
  flashSaleStartTime DateTime?
  flashSaleEndTime   DateTime?
  restaurantId       String
  categoryId         Int
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  orders             Order[]
  category           Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant         Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reviews            Review[]    // <-- Relasi ke tabel Review
}

model Order {
  id                String       @id @default(uuid())
  userId            String
  productId         String
  itemPrice         Int
  quantity          Int          @default(1)
  platformFeeBuyer  Int          @default(0)
  platformFeeSeller Int          @default(0)
  totalPaidByBuyer  Int
  netSellerRevenue  Int
  deliveryType      DeliveryType
  status            OrderStatus  @default(WAITING_PAYMENT)
  proofUrl          String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  product           Product      @relation(fields: [productId], references: [id])
  user              User         @relation(fields: [userId], references: [id])
  review            Review?      // <-- Relasi ke tabel Review (Satu order hanya boleh punya satu review)
}

// --- MODEL BARU UNTUK RATING & ULASAN ---
model Review {
  id        String   @id @default(uuid())
  rating    Int      // Menyimpan bintang 1 sampai 5
  comment   String?  // Ulasan teks
  
  userId    String
  productId String
  orderId   String   @unique // 1 pesanan hanya boleh diberi 1 ulasan
  
  createdAt DateTime @default(now())

  // Relasi
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])
}

enum Role {
  CUSTOMER
  MERCHANT
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  WAITING_PAYMENT
  PREPARING
  READY_FOR_PICKUP
  ON_THE_WAY
  COMPLETED
  CANCELLED
}

enum ProductType {
  REGULAR
  DAILY_PERISHABLE
  FLASH_SALE
}